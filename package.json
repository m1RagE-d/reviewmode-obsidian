{
  "name": "obsidian-critic-track",
  "version": "0.1.0",
  "description": "Track changes with CriticMarkup in Obsidian",
  "main": "main.js",
  "scripts": {
    "build": "esbuild src/main.ts --bundle --outfile=main.js --external:obsidian --external:@codemirror/view --external:@codemirror/state --external:@codemirror/language --format=cjs --platform=node --target=es2018",
    "dev": "esbuild src/main.ts --bundle --outfile=main.js --external:obsidian --external:@codemirror/view --external:@codemirror/state --external:@codemirror/language --format=cjs --platform=node --target=es2018 --watch"
  },
  "devDependencies": {
    "@types/node": "^18.0.0",
    "esbuild": "^0.17.0",
    "obsidian": "latest",
    "typescript": "^5.0.0"
  }
}
